# Application
APP_NAME=Tour SaaS API
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/tour_saas
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Email
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@toursaas.com
FROM_NAME=Tour SaaS
ADMIN_ERROR_EMAIL=harideepa0611@gmail.com

# AWS (for S3 storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=tour-saas-images

# CORS
#CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# PDF Quote Generation — Image Prefetch
# Controls how many activity/logo images are downloaded in parallel before
# the ReportLab PDF render thread starts. Higher values = faster generation
# but more outbound connections per request.
#   Recommended values:
#     Low-resource server or CDN with rate limits  →  3–5
#     Standard production deployment               →  10  (default)
#     High-memory server with fast CDN             →  15–20
PDF_IMAGE_PREFETCH_CONCURRENCY=10
