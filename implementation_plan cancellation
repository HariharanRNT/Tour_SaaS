### 3. Backend — Cancellation Service

#### [NEW] `cancellation_service.py`

**Key patterns:**

```python
import logging
from pytz import timezone as tz

logger = logging.getLogger(__name__)

def calculate_refund(booking, rules: list) -> dict:
    india_today = datetime.now(tz("Asia/Kolkata")).date()
    days_before = (booking.travel_date - india_today).days
    paid = sum(float(p.amount) for p in booking.payments if p.status == "succeeded")

    if days_before < 0:
        logger.info(f"[{booking.id}] Travel date passed — no refund")
        return {"refund_amount": 0, "refund_percentage": 0, "days_before": days_before, "paid_amount": paid}

    # Rules stored pre-sorted (descending daysBefore)
    applicable = next((r for r in rules if days_before >= r["daysBefore"]), None)
    pct = applicable["refundPercentage"] if applicable else 0
    amount = round(paid * pct / 100, 2)
    logger.info(f"[{booking.id}] days_before={days_before}, rule_pct={pct}%, refund={amount}")
    return {"refund_amount": amount, "refund_percentage": pct, "days_before": days_before, "paid_amount": paid}


async def process_cancellation(booking_id, db) -> dict:
    # 1. Lock row to prevent race conditions
    stmt = select(Booking).where(Booking.id == booking_id).with_for_update().options(
        selectinload(Booking.payments), selectinload(Booking.package).selectinload(Package.creator)
    )
    result = await db.execute(stmt)
    booking = result.scalar_one_or_none()
    if not booking:
        raise ValueError("Booking not found")

    # 2. Idempotency guards
    if booking.status == BookingStatus.CANCELLED:
        raise ValueError("Booking is already cancelled")
    india_today = datetime.now(tz("Asia/Kolkata")).date()
    if booking.travel_date < india_today:
        raise ValueError("Travel date has already passed")

    try:
        # 3. Calculate refund
        rules = booking.package.cancellation_rules or []
        calc  = calculate_refund(booking, rules)

        # 4. Find the latest succeeded payment
        succeeded = next((p for p in reversed(booking.payments) if p.status == "succeeded"), None)
        payment_id  = succeeded.razorpay_payment_id if succeeded else None

        # 5. Resolve agent Razorpay keys
        creator  = booking.package.creator
        rp_cfg   = creator.agent_profile.razorpay_settings if creator and creator.agent_profile else None
        rp_refund_id = None
        refund_status = "pending"
        failure_reason = None

        if calc["refund_amount"] > 0 and payment_id and rp_cfg:
            try:
                result = RazorpayService.refund_payment(
                    payment_id=payment_id,
                    amount_paise=int(calc["refund_amount"] * 100),
                    key_id=decrypt(rp_cfg.key_id),
                    key_secret=decrypt(rp_cfg.key_secret)
                )
                rp_refund_id  = result.get("id")
                refund_status = "succeeded" if rp_refund_id else "failed"
                logger.info(f"[{booking.id}] Razorpay refund {refund_status}: {rp_refund_id}")
            except Exception as e:
                refund_status  = "pending"
                failure_reason = str(e)
                logger.error(f"[{booking.id}] Razorpay refund failed: {e}")

        # 6. Persist refund record
        refund_record = BookingRefund(
            booking_id=booking.id,
            razorpay_payment_id=payment_id,
            razorpay_refund_id=rp_refund_id,
            refund_amount=calc["refund_amount"],
            refund_percentage=calc["refund_percentage"],
            days_before=calc["days_before"],
            status=refund_status,
            failure_reason=failure_reason
        )
        db.add(refund_record)

        # 7. Update booking
        booking.status        = BookingStatus.CANCELLED
        booking.refund_amount = calc["refund_amount"]
        booking.cancelled_at  = datetime.now(tz("Asia/Kolkata"))

        await db.commit()

        return {**calc, "refund_status": refund_status, "failure_reason": failure_reason}

    except Exception:
        await db.rollback()
        raise
```

