```python
def validate_and_sort_rules(rules: list) -> list:
    for r in rules:
        if not (0 <= r["refundPercentage"] <= 100):
            raise HTTPException(400, "refundPercentage must be 0–100")
    days = [r["daysBefore"] for r in rules]
    if len(days) != len(set(days)):
        raise HTTPException(400, "Duplicate daysBefore values")
    sorted_rules = sorted(rules, key=lambda x: -x["daysBefore"])
    if rules != sorted_rules:
        raise HTTPException(400, "Rules must be in descending daysBefore order")
    # Auto fallback: if enabled but no rules, add 0% rule
    return sorted_rules or [{"daysBefore": 0, "refundPercentage": 0}]
```
